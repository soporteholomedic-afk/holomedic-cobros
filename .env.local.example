# SMTP Configuration for email sending via Google Workspace
# Copy this file to .env.local and fill in your credentials
# NOTE: With MFA enabled, use an App Password (not your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=
# SMTP credentials are per-purpose. Each purpose X reads SMTP_USER_X and SMTP_PASS_X.
# To add a new purpose: extend the Purpose union in src/utils/sendEmail.ts and add the 2 env vars here.
# BREAKING: production .env.local must rename SMTP_USER → SMTP_USER_FACTURACION and SMTP_PASS → SMTP_PASS_FACTURACION.
SMTP_USER_FACTURACION=
SMTP_PASS_FACTURACION=
SMTP_USER_CONSOLIDADOS=
SMTP_PASS_CONSOLIDADOS=

# File server (LAN UNC share, read-only, anonymous on LAN).
# Production Windows runtime resolves this directly via Node fs.
# Example: \\host\share  (NO trailing slash, NO host duplication).
FILE_SERVER_BASE_PATH=
